--- !u!114 &6403791909845345636
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5422197824231970161}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 99229a359d5cf154dbb529bc12e224d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  fadeTime: 2
  button: {fileID: 8300000, guid: 4bcda8eaa373c3e4aabf6d9ecf574c1f, type: 3}
  bgm: {fileID: 8300000, guid: 6961d5fc01528d74a833bd712dfc2a64, type: 3}
  cutScenes:
  - sprite: {fileID: 21300000, guid: c450d4be2227b5c4aa0a2aad8ebd91c6, type: 3}
    texts: PRESS SPACE BUTTON TO START
  - sprite: {fileID: 21300000, guid: 472f24b9270f083448e45d8e56553287, type: 3}
    texts: "\uC11C\uAE30 5700\uB144.  \uC778\uB958\uB294 \uB9C8\uCE68\uB0B4 \uBCC4\uC758
      \uC2DC\uB300\uC5D0 \uB3C4\uB2EC\uD588\uB2E4.  \uAE30\uC220\uC740 \uBB38\uBA85\uC744
      \uC774\uC804\uACFC \uBE44\uAD50\uD560 \uC218 \uC5C6\uC744 \uC815\uB3C4\uB85C
      \uBC1C\uC804\uC2DC\uCF30\uB2E4.  \uC218\uB9CE\uC740 \uC138\uACC4\uAC00 \uC5F0\uACB0\uB418\uC5C8\uACE0,
      \uC778\uB958\uC758 \uC601\uD5A5\uB825\uC740 \uC740\uD558 \uACF3\uACF3\uC73C\uB85C
      \uBED7\uC5B4\uB098\uAC14\uB2E4."
  - sprite: {fileID: 21300000, guid: a70cd140778118a4192c63ebf5fb924f, type: 3}
    texts: "\uD558\uC9C0\uB9CC \uBC1C\uC804\uC5D0\uB294 \uB9C9\uB300\uD55C \uC5D0\uB108\uC9C0\uAC00
      \uD544\uC694\uD588\uACE0 \uC778\uB958\uB294 \uC0C8\uB85C\uC6B4 \uC790\uC6D0\uC744
      \uCC3E\uC544 \uC6B0\uC8FC \uACF3\uACF3\uC73C\uB85C \uC9C4\uCD9C\uD558\uAE30
      \uC2DC\uC791\uD588\uB2E4."
  - sprite: {fileID: 21300000, guid: 5c254e5a6bcb1fc4c9c7908cf6c04ec4, type: 3}
    texts: "\uADF8\uB9AC\uACE0 \uADF8 \uC911\uC2EC\uC5D0\uB294 DFP\uAC00 \uC788\uC5C8\uB2E4. 
      \uC678\uACC4 \uC790\uC6D0 \uAC1C\uBC1C\uC758 \uC120\uB450\uC8FC\uC790.  \uC778\uB958\uC758
      \uBC88\uC601\uC744 \uC774\uB044\uB294 \uC138\uACC4 \uCD5C\uB300 \uAE30\uC5C5. 
      DFP\uB294 \uC218\uB9CE\uC740 \uD589\uC131\uC5D0\uC11C \uC0C8\uB85C\uC6B4 \uC790\uC6D0\uC744
      \uBC1C\uACAC\uD558\uBA70 \uC778\uB958\uC5D0\uAC8C \uBB34\uD55C\uD55C \uAC00\uB2A5\uC131\uC744
      \uC120\uC0AC\uD588\uB2E4."
  - sprite: {fileID: 21300000, guid: 93c7841511f779b42a0db3c37d56f068, type: 3}
    texts: "DFP\uC758 \uC5F0\uAD6C\uC9C4\uC740 \uD68D\uAE30\uC801\uC778 \uBB3C\uC9C8
      \uBCC0\uD658 \uAE30\uC220\uC744 \uAC1C\uBC1C\uD588\uB2E4.  \uC774\uB97C \uD1B5\uD574
      \uC678\uACC4 \uC790\uC6D0\uC744 \uB2E4\uC591\uD55C \uD615\uD0DC\uB85C \uAC00\uACF5\uD558\uACE0
      \uD65C\uC6A9\uD560 \uC218 \uC788\uAC8C \uB418\uC5C8\uB2E4.  \uADF8\uB9AC\uACE0
      \uC774 \uAE30\uC220\uC740 \uC6B0\uC8FC \uAC1C\uCC99\uC758 \uC0C8\uB85C\uC6B4
      \uC2DC\uB300\uB97C \uC5F4\uAC8C \uB41C\uB2E4."
  - sprite: {fileID: 21300000, guid: cec21acdb29b05c43916403c8f3e01ad, type: 3}
    texts: "DFP\uB294 \uCD5C\uCCA8\uB2E8 \uC778\uACF5\uC9C0\uB2A5 \uB85C\uBD07, \uC5D0\uC774\uD329\uC2A4\uB97C
      \uAC1C\uBC1C\uD588\uB2E4.  \uD0D0\uC0AC. \uAD6C\uC870. \uAC1C\uCC99.  \uC778\uAC04\uC774
      \uB2FF\uC9C0 \uBABB\uD558\uB294 \uACF3\uC5D0\uC11C \uADF8\uB4E4\uC740 \uC0C8\uB85C\uC6B4
      \uBBF8\uB798\uB97C \uB9CC\uB4E4\uC5B4\uAC14\uB2E4.  \uC218\uB9CE\uC740 \uD589\uC131\uC774
      \uC5D0\uC774\uD329\uC2A4\uC5D0 \uC758\uD574 \uAC1C\uCC99\uB418\uC5C8\uB2E4."
  - sprite: {fileID: 21300000, guid: 7accc40db4bd3bd47894dde8c0c286ae, type: 3}
    texts: "\uADF8\uB9AC\uACE0 \uC9C0\uAE08.  \uC0C8\uB85C\uC6B4 \uC784\uBB34\uB97C
      \uB9E1\uC744 \uAC1C\uCCB4\uAC00 \uAE30\uB3D9\uD55C\uB2E4.  \uCF54\uB4DC\uBA85... 
      \uC5D0\uC774\uD329\uC2A4-26."
  - sprite: {fileID: 21300000, guid: 36a96fe09792e3c46b41d1d0f9dc180f, type: 3}
    texts: "\uBAA9\uC801\uC9C0\uB294 \uC544\uB974\uB378\uB9AC\uC628.  \uBBF8\uC9C0\uC758
      \uC0DD\uD0DC\uACC4\uC640 \uD48D\uBD80\uD55C \uC790\uC6D0\uC744 \uAC00\uC9C4
      \uD589\uC131.  \uADF8\uB9AC\uACE0 \uADF8 \uC911\uC2EC\uC5D0\uB294...  \uCF54\uC5B4\uB77C
      \uBD88\uB9AC\uB294 \uC2E0\uBE44\uD55C \uC5D0\uB108\uC9C0\uC6D0\uC774 \uC874\uC7AC\uD55C\uB2E4."
  - sprite: {fileID: 21300000, guid: fef0c83e8f28dd74590be2b2f1f0a660, type: 3}
    texts: "\uC544\uC9C1 \uBC1D\uD600\uC9C0\uC9C0 \uC54A\uC740 \uC138\uACC4.  \uBB34\uD55C\uD55C
      \uAC00\uB2A5\uC131\uC744 \uD488\uC740 \uD589\uC131.  \uC778\uB958\uC758 \uC0C8\uB85C\uC6B4
      \uBBF8\uB798\uAC00 \uADF8\uACF3\uC5D0\uC11C \uAE30\uB2E4\uB9AC\uACE0 \uC788\uB2E4."
  - sprite: {fileID: 21300000, guid: 07fc2a32bdcfafc448b135496f371805, type: 3}
    texts: "\uC0C8\uB85C\uC6B4 \uC784\uBB34.  \uC0C8\uB85C\uC6B4 \uC138\uACC4.  \uC778\uB958\uC758
      \uBBF8\uB798\uB294...  \uC774\uC81C \uC5D0\uC774\uD329\uC2A4-26\uC758 \uC190\uC5D0
      \uB2EC\uB824 \uC788\uB2E4."
